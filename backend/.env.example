# Node Environment
NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=mongodb+srv://shubhamdubeydubey4_db_user:zda5pox3pJt2PDFB@cluster-console.q0wlsga.mongodb.net/console2.0?appName=Cluster-Console


# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production
REFRESH_TOKEN_EXPIRES_IN=30d

# Encryption (must be 32 characters for AES-256)
ENCRYPTION_KEY=12345678901234567890123456789012

# Meta Platform
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_API_VERSION=v18.0
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
OAUTH_REDIRECT_URI=http://localhost:3000/api/instagram/callback

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=instagram-dm-saas-uploads

# Frontend
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
